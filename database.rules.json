{
  "rules": {
    ".read": false,
    ".write": false,

    "licenses": {
      ".read": true,
      ".write": false
    },

    "rooms": {
      "$roomId": {
        ".read": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".write": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".validate": "newData.hasChildren(['roomId','status','players']) && newData.child('roomId').isString() && newData.child('roomId').val().matches(/^[0-9]{4,6}$/) && newData.child('roomId').val() === $roomId",

        "pin": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^[0-9]{4,6}$/))"
        },
        "hostUid": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0)"
        },
        "players": {
          ".validate": "newData.hasChildren()",
          "$uid": {
            ".validate": "!newData.exists() || (newData.child('uid').isString() && newData.child('name').isString())"
          }
        }
      }
    },

    "$gameRooms": {
      "$roomId": {
        ".read": false,
        ".write": false,

        "public": {
          ".read": "$gameRooms.matches(/^[a-z0-9_]+_rooms$/) && $gameRooms !== 'rooms' && $gameRooms !== 'duel_rooms' && auth != null && root.child('rooms/' + $roomId + '/players/' + auth.uid).exists()",
          ".write": "$gameRooms.matches(/^[a-z0-9_]+_rooms$/) && $gameRooms !== 'rooms' && $gameRooms !== 'duel_rooms' && auth != null && root.child('rooms/' + $roomId + '/players/' + auth.uid).exists()",
          "hostUid": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0)"
          }
        },

        "private": {
          ".read": "$gameRooms.matches(/^[a-z0-9_]+_rooms$/) && $gameRooms !== 'rooms' && $gameRooms !== 'duel_rooms' && auth != null && root.child('rooms/' + $roomId + '/players/' + auth.uid).exists()",
          ".write": "$gameRooms.matches(/^[a-z0-9_]+_rooms$/) && $gameRooms !== 'rooms' && $gameRooms !== 'duel_rooms' && auth != null && root.child('rooms/' + $roomId + '/players/' + auth.uid).exists()",
          "$uid": {
            ".read": "$gameRooms.matches(/^[a-z0-9_]+_rooms$/) && $gameRooms !== 'rooms' && $gameRooms !== 'duel_rooms' && auth != null && root.child('rooms/' + $roomId + '/players/' + auth.uid).exists()",
            ".write": "$gameRooms.matches(/^[a-z0-9_]+_rooms$/) && $gameRooms !== 'rooms' && $gameRooms !== 'duel_rooms' && auth != null && root.child('rooms/' + $roomId + '/players/' + auth.uid).exists()"
          }
        }
      }
    },

    "duel_rooms": {
      "$roomId": {
        ".read": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".write": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".validate": "newData.hasChildren(['roomId','status','players']) && newData.child('roomId').isString() && newData.child('roomId').val().matches(/^[0-9]{4,6}$/) && newData.child('roomId').val() === $roomId"
      }
    }
  }
}
