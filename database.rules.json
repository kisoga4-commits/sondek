{
  "rules": {
    ".read": false,
    ".write": false,

    "licenses": {
      ".read": true,
      ".write": false
    },

    "rooms": {
      "$roomId": {
        ".read": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".write": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".validate": "newData.hasChildren(['roomId','status','players']) && newData.child('roomId').isString() && newData.child('roomId').val().matches(/^[0-9]{4,6}$/) && newData.child('roomId').val() === $roomId",

        "pin": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^[0-9]{4,6}$/))"
        },
        "hostUid": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0)"
        },
        "players": {
          ".validate": "newData.hasChildren()",
          "$uid": {
            ".validate": "!newData.exists() || (newData.child('uid').isString() && newData.child('name').isString())"
          }
        }
      }
    },

    "pob_rooms": {
      "$roomId": {
        ".read": "auth != null && root.child('rooms').child($roomId).exists()",
        ".write": "auth != null && root.child('rooms').child($roomId).exists()",

        "public": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || root.child('rooms').child($roomId).child('hostUid').val() === auth.uid)",
          "hostUid": {
            ".validate": "!newData.exists() || newData.val() === root.child('rooms').child($roomId).child('hostUid').val()"
          }
        },

        "private": {
          "$uid": {
            ".read": "auth != null && (auth.uid === $uid || root.child('rooms').child($roomId).child('hostUid').val() === auth.uid)",
            ".write": "auth != null && (auth.uid === $uid || root.child('rooms').child($roomId).child('hostUid').val() === auth.uid)"
          }
        }
      }
    },

    "duel_rooms": {
      "$roomId": {
        ".read": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".write": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".validate": "newData.hasChildren(['roomId','status','players']) && newData.child('roomId').isString() && newData.child('roomId').val().matches(/^[0-9]{4,6}$/) && newData.child('roomId').val() === $roomId"
      }
    }
  }
}
