{
  "rules": {
    ".read": false,
    ".write": false,
    "duel_rooms": {
      "$roomId": {
        ".read": "auth != null && $roomId.matches(/^[0-9]{4}$/)",
        ".write": "auth != null && $roomId.matches(/^[0-9]{4}$/)",
        ".validate": "newData.hasChildren(['roomId', 'status', 'players', 'updatedAtMs']) && newData.child('roomId').val() === $roomId && newData.child('players').childrenCount() <= 2"
      }
    }
  }
}
