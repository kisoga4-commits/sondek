{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomId": {
        ".read": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        ".write": "auth != null && $roomId.matches(/^[0-9]{4,6}$/)",
        "players": {
          "$uid": {
            ".validate": "newData.hasChildren(['name'])"
          }
        },
        "settings": {
          ".validate": "newData.hasChildren(['mode','competitionType','durationMinutes','quizId'])"
        },
        "state": {
          ".validate": "newData.hasChildren(['status'])"
        }
      }
    },
    "duel_rooms": {
      ".read": false,
      ".write": false
    }
  }
}
