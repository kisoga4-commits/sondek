rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // เช็กว่ามีการยืนยันตัวตนแล้ว
    // รวมถึง Anonymous Auth ด้วย
    function isAuthenticated() {
      return request.auth != null;
    }

    // -----------------------------
    // 1) คอร์ส / ข้อสอบ / ตั้งค่า / โปรไฟล์
    // อ่านได้สาธารณะ
    // เขียนได้เฉพาะคนที่ login แล้ว
    // -----------------------------
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /profile/{profileId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /course_offerings/{courseId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // -----------------------------
    // 2) leads = รายชื่อผู้เข้าสอบ / คะแนน / leaderboard
    // ตามโหมดง่าย: ต้อง login ก่อน ถึงจะอ่าน/เขียนได้
    // -----------------------------
    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // -----------------------------
    // โหมดดวลเรียลไทม์
    // -----------------------------

    function isValidRoomId(roomId) {
      return roomId.matches('^[0-9]{4,6}$');
    }

    // -----------------------------
    // ระบบหมู่บ้านอาถรรพ์ (Secret Village)
    // โครงสร้างนี้ใช้ร่วมกับเกมอื่นในอนาคตได้ โดยเพิ่ม sub-collection แบบ private
    // -----------------------------
    match /duel_rooms/{roomId} {
      // ข้อมูลสาธารณะในห้อง: ผู้เล่น, สถานะเป็น/ตาย, เฟสเกม
      allow read: if isValidRoomId(roomId);
      allow create, update, delete: if isAuthenticated() && isValidRoomId(roomId);
    }

    // ข้อมูลลับของผู้เล่นรายคน เช่น role / คำสั่งลับ
    // path: /duel_rooms/{roomId}/private_players/{userId}
    match /duel_rooms/{roomId}/private_players/{userId} {
      // อ่าน/เขียนได้เฉพาะเจ้าของ UID เท่านั้น
      allow read, write: if isAuthenticated() && isValidRoomId(roomId) && request.auth.uid == userId;
    }

    // -----------------------------
    // 3) ปิดทุก collection อื่นที่ไม่ได้ระบุ
    // -----------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
