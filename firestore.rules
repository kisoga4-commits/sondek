rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // เช็กว่ามีการยืนยันตัวตนแล้ว
    // รวมถึง Anonymous Auth ด้วย
    function isAuthenticated() {
      return request.auth != null;
    }

    // -----------------------------
    // 1) คอร์ส / ข้อสอบ / ตั้งค่า / โปรไฟล์
    // อ่านได้สาธารณะ
    // เขียนได้เฉพาะคนที่ login แล้ว
    // -----------------------------
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /profile/{profileId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // -----------------------------
    // 2) leads = รายชื่อผู้เข้าสอบ / คะแนน / leaderboard
    // ตามโหมดง่าย: ต้อง login ก่อน ถึงจะอ่าน/เขียนได้
    // -----------------------------
    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // -----------------------------
    // โหมดดวลเรียลไทม์
    // -----------------------------

    function isValidRoomId(roomId) {
      return roomId.matches('^[0-9]{4}$');
    }

    match /duel_rooms/{roomId} {
      // โหมดดวลต้องให้ผู้เล่นที่ sign-in (รวม anonymous) create/join ได้ทันที
      // ปิด guest เพื่อกันการเขียนโดยไม่ระบุตัวตน
      allow read: if isValidRoomId(roomId);
      allow create, update, delete: if isAuthenticated() && isValidRoomId(roomId);
    }

    // -----------------------------
    // 3) ปิดทุก collection อื่นที่ไม่ได้ระบุ
    // -----------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
